# Gruvbox Dark color scheme
foreground #ebdbb2
background #282828

# Cursor
cursor #ffffff
cursor_text_color #000000
cursor_shape block
cursor_blink_interval 0

# Normal colors
color0 #282828
color1 #cc241d
color2 #98971a
color3 #d79921
color4 #458588
color5 #b16286
color6 #689d6a
color7 #a89984

# Bright colors
color8  #928374
color9  #fb4934
color10 #b8bb26
color11 #fabd2f
color12 #83a598
color13 #d3869b
color14 #8ec07c
color15 #ebdbb2

# Font
font_family Liga SFMono Nerd Font
font_size 12

# Shell
shell /bin/zsh

# Window
hide_window_decorations titlebar-only
macos_option_as_alt yes

# Terminal
term xterm-256color
clipboard_control write-clipboard read-clipboard

# Window size (columns x lines)
initial_window_width 250c
initial_window_height 70c

# Behavior
confirm_os_window_close 0
