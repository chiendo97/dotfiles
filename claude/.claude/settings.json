{
  "env": {
    "DISCORD_GUILD_ID": "1181560951141584926",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/telegram-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/ccline/ccline",
    "padding": 0
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "impeccable@impeccable": true,
    "code-simplifier@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "linus-torvalds-skills@linus-torvalds-skills": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/forrestchang/andrej-karpathy-skills.git"
      }
    },
    "linus-torvalds-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/leopiney/linus-torvalds-skills.git"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true
}
