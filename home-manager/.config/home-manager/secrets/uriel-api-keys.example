# Uriel work API keys - copy and encrypt with:
# age -r "$(cat ~/.ssh/id_ed25519_agenix.pub)" -r "$(cat ~/.ssh/id_ed25519_uriel_dev.pub)" -o uriel-api-keys.age uriel-api-keys.txt

# Services
export POSTMAN_API_KEY="your-key-here"
export DISCORD_TOKEN="your-discord-token-here"
export GITLAB_TOKEN="your-token-here"

# GitHub
export GITHUB_TOKEN="your-token-here"
export GITHUB_APP_ID="your-app-id-here"
export GITHUB_APP_INSTALLATION_ID="your-installation-id-here"
export GITHUB_APP_PRIVATE_KEY='your-private-key-here'

# Notion
export NOTION_TOKEN="your-notion-token-here"
export NOTION_DATABASE_ID="your-database-id-here"
